# TokenFlow Router — environment variables
# Copy to .env and fill in values

TOKENFLOW_HOST=0.0.0.0
TOKENFLOW_PORT=8080
TOKENFLOW_LOG_LEVEL=INFO
TOKENFLOW_WORKERS=1

# Policy file path (optional — if not set, uses default balanced policy)
# TOKENFLOW_POLICY_FILE=/app/configs/policy.yaml

# Routing
TOKENFLOW_DEFAULT_POLICY=balanced
TOKENFLOW_MAX_FALLBACK_ATTEMPTS=3
TOKENFLOW_ROUTE_TIMEOUT_MS=10

# Telemetry
TOKENFLOW_TELEMETRY_SCRAPE_INTERVAL_S=10
TOKENFLOW_TELEMETRY_STALE_THRESHOLD_S=60
TOKENFLOW_TELEMETRY_SMOOTHING_ALPHA=0.3

# Upstream
TOKENFLOW_UPSTREAM_TIMEOUT_S=120
TOKENFLOW_UPSTREAM_CONNECT_TIMEOUT_S=5

# Optional admin API key (if set, all /admin/* routes require Authorization: Bearer <key>)
# TOKENFLOW_ADMIN_API_KEY=your-secret-key

# Observability
TOKENFLOW_ENABLE_METRICS=true
